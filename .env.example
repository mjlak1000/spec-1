# SPEC-1 Environment Configuration
# Copy to .env and fill in values

# Storage
SPEC1_STORE_PATH=spec1_intelligence.jsonl
SPEC1_DB_PATH=spec1.db
SPEC1_ENVIRONMENT=production
SPEC1_LOG_LEVEL=INFO

# Anthropic API (for investigation verification and briefing generation)
ANTHROPIC_API_KEY=sk-ant-...

# API Server
SPEC1_API_HOST=0.0.0.0
SPEC1_API_PORT=8000

# Scheduler (cron expression for daily cycle, default: 06:00 LA time)
SPEC1_CRON_HOUR=6
SPEC1_CRON_MINUTE=0
SPEC1_TIMEZONE=America/Los_Angeles

# Feed timeouts
SPEC1_FEED_TIMEOUT=15

# Quant (optional — requires yfinance)
SPEC1_QUANT_ENABLED=false
